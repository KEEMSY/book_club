# =============================================================================
# Book Club — environment variables template.
#
# Usage: `cp .env.example .env` and fill in real values. `.env` is git-ignored
# (see CLAUDE.md §9). Keys here mirror 1:1 the fields on `Settings` in
# backend/app/core/config.py — do not rename without updating both.
# =============================================================================

# ─── Runtime ────────────────────────────────────────────────────────────────
# env ∈ { dev | staging | prod | test }
ENV=dev

# ─── Database (Postgres 16) ─────────────────────────────────────────────────
# Driver must be asyncpg (app uses SQLAlchemy async engine).
# Host `db` resolves inside the compose network.
DATABASE_URL=postgresql+asyncpg://bookclub:bookclub@db:5432/bookclub

# ─── Cache / Bus (Redis 7) ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Object Storage (Cloudflare R2 in prod / MinIO locally) ─────────────────
# Locally points at the minio service; prod overrides with R2 account endpoint.
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=bookclub-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=auto

# ─── JWT ────────────────────────────────────────────────────────────────────
# In production use Fly.io secrets; never commit the real value.
JWT_SECRET=change-me-in-production-use-fly-secrets
JWT_ALG=HS256
# Access / refresh TTLs (seconds). Defaults in config.py are fine for dev.
# JWT_ACCESS_TTL_SECONDS=3600
# JWT_REFRESH_TTL_SECONDS=2592000

# ─── External OAuth / Book APIs ─────────────────────────────────────────────
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── CORS ───────────────────────────────────────────────────────────────────
# NOTE: Settings.cors_allow_origins is `list[str]`, parsed by pydantic-settings
# as JSON. Keep the JSON-array form below — a comma-separated string will NOT
# parse. Add your Flutter web preview / tunnel origin here as needed.
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8080"]
