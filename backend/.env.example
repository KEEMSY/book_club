# Book Club Backend — 환경변수 예시
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env 는 .gitignore 에 의해 커밋되지 않습니다.

# ── 실행 환경 ──────────────────────────────────────────────
ENV=dev   # dev | staging | prod | test

# ── 데이터베이스 ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bookclub:bookclub@localhost:5432/bookclub

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (로컬: MinIO / 프로덕션: Cloudflare R2) ──
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=bookclub-local
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_REGION=auto

# ── JWT ────────────────────────────────────────────────────
# 프로덕션에서는 반드시 강한 난수로 교체하세요.
JWT_SECRET=change-me-in-production
JWT_ALG=HS256

# ── 카카오 ─────────────────────────────────────────────────
# 발급 위치: https://developers.kakao.com → 내 애플리케이션 → 앱 키
# REST API 키: 책 검색(Kakao Book API 폴백) + 미래 서버-사이드 OAuth용
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# ── 네이버 책 API ───────────────────────────────────────────
# 발급 위치: https://developers.naver.com → 애플리케이션 → 검색 API
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ── Apple Sign In ───────────────────────────────────────────
# 발급 위치: Apple Developer → Certificates → Identifiers → Services IDs
# apple_client_id: App Store Connect 번들 ID (com.yourcompany.bookclub)
APPLE_CLIENT_ID=com.yourcompany.bookclub
